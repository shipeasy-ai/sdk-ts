{
  "name": "@shipeasy/sdk",
  "version": "7.8.3",
  "description": "Shipeasy SDK — feature gates, runtime configs, experiments, and metrics for the Shipeasy hosted service.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://shipeasy.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/shipeasy-ai/sdk-ts.git"
  },
  "bugs": {
    "url": "https://github.com/shipeasy-ai/sdk-ts/issues"
  },
  "main": "./dist/server/index.js",
  "module": "./dist/server/index.mjs",
  "browser": "./dist/client/index.js",
  "react-native": "./dist/client/index.js",
  "typesVersions": {
    "*": {
      "client": [
        "./dist/client/index.d.ts"
      ],
      "server": [
        "./dist/server/index.d.ts"
      ],
      "next": [
        "./dist/next/index.d.ts"
      ],
      "devtools": [
        "./dist/devtools/index.d.ts"
      ],
      "react-native-devtools": [
        "./dist/react-native-devtools/index.d.ts"
      ],
      "browser-devtools": [
        "./dist/browser-devtools/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "react-native": "./dist/client/index.js",
      "node": "./dist/server/index.js",
      "browser": "./dist/client/index.js",
      "default": "./dist/server/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.mjs",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.mjs",
      "default": "./dist/next/index.js"
    },
    "./openfeature-server": {
      "types": "./dist/openfeature-server/index.d.ts",
      "import": "./dist/openfeature-server/index.mjs",
      "default": "./dist/openfeature-server/index.js"
    },
    "./openfeature-web": {
      "types": "./dist/openfeature-web/index.d.ts",
      "import": "./dist/openfeature-web/index.mjs",
      "default": "./dist/openfeature-web/index.js"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "import": "./dist/devtools/index.mjs",
      "default": "./dist/devtools/index.js"
    },
    "./react-native-devtools": {
      "types": "./dist/react-native-devtools/index.d.ts",
      "react-native": "./dist/react-native-devtools/index.js",
      "import": "./dist/react-native-devtools/index.mjs",
      "default": "./dist/react-native-devtools/index.js"
    },
    "./browser-devtools": {
      "types": "./dist/browser-devtools/index.d.ts",
      "import": "./dist/browser-devtools/index.mjs",
      "default": "./dist/browser-devtools/index.js"
    },
    "./templates/*": "./templates/*.js"
  },
  "bin": {
    "shipeasy-skill": "./dist/skill-cli.js"
  },
  "files": [
    "dist/server/",
    "dist/client/",
    "dist/next/",
    "dist/openfeature-server/",
    "dist/openfeature-web/",
    "dist/devtools/",
    "dist/react-native-devtools/",
    "dist/skill-cli.js",
    "docs/skill/SKILL.md",
    "templates/",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "gen:readme": "node scripts/gen-readme.mjs",
    "gen:devtools": "openapi-ts",
    "refresh:spec": "node scripts/refresh-devtools-spec.mjs",
    "publish-loader": "wrangler r2 object put shipeasy-sdk/loader-v$npm_package_version.js --file=dist/loader/loader.global.js --content-type 'application/javascript; charset=utf-8' --cache-control 'public, max-age=31536000, immutable' --remote && wrangler r2 object put shipeasy-sdk/loader.js --file=dist/loader/loader.global.js --content-type 'application/javascript; charset=utf-8' --cache-control 'public, max-age=300' --remote"
  },
  "dependencies": {
    "murmurhash-js": "^1.0.0"
  },
  "peerDependencies": {
    "@hookform/resolvers": ">=3",
    "@openfeature/server-sdk": ">=1.13.0",
    "@openfeature/web-sdk": ">=1.2.0",
    "expo-crypto": ">=13",
    "expo-image-picker": ">=15",
    "expo-secure-store": ">=13",
    "expo-sensors": ">=13",
    "expo-web-browser": ">=13",
    "next": ">=13",
    "react": ">=18",
    "react-hook-form": ">=7.50",
    "react-native": ">=0.73",
    "react-native-svg": ">=12",
    "zod": ">=4"
  },
  "peerDependenciesMeta": {
    "@hookform/resolvers": {
      "optional": true
    },
    "@openfeature/server-sdk": {
      "optional": true
    },
    "@openfeature/web-sdk": {
      "optional": true
    },
    "expo-crypto": {
      "optional": true
    },
    "expo-image-picker": {
      "optional": true
    },
    "expo-secure-store": {
      "optional": true
    },
    "expo-sensors": {
      "optional": true
    },
    "expo-web-browser": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    },
    "react-hook-form": {
      "optional": true
    },
    "react-native": {
      "optional": true
    },
    "react-native-svg": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@hey-api/openapi-ts": "^0.99.0",
    "@hookform/resolvers": "^5.4.0",
    "@openfeature/server-sdk": "^1.22.0",
    "@openfeature/web-sdk": "^1.9.0",
    "@testing-library/react": "^16.3.2",
    "@types/murmurhash-js": "^1.0.6",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.14",
    "axios": "^1.18.1",
    "jsdom": "^29.1.1",
    "next": "^16.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.81.0",
    "react-native": "^0.81.6",
    "tsup": "^8.3.0",
    "typescript": "^6.0.3",
    "vite": "^6.4.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.83.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
