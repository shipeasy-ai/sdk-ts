{
  "compilerOptions": {
    // tsup's dts step injects `baseUrl`, which TypeScript 6 flags as deprecated
    // (removed in 7). Acknowledge it so `pnpm run build` doesn't error out; the
    // SDK itself sets no baseUrl.
    "ignoreDeprecations": "6.0",
    "target": "es2024",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "allowJs": true,
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "noEmit": false,
    "incremental": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
